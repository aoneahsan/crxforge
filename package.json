{
  "name": "crxforge",
  "version": "1.0.0",
  "description": "CrxForge — a production-ready, cross-browser (Chrome, Firefox, Edge) browser-extension starter built with WXT, React 19, Radix UI Themes, TypeScript, and Zustand. Store-compliant by default: Chrome Identity auth, bundled analytics, and typed storage + messaging.",
  "author": {
    "name": "Ahsan Mahmood",
    "email": "aoneahsan@gmail.com",
    "url": "https://aoneahsan.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/aoneahsan/crxforge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aoneahsan/crxforge.git"
  },
  "bugs": {
    "url": "https://github.com/aoneahsan/crxforge/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://aoneahsan.com/payment?project-id=crxforge&project-identifier=crxforge"
  },
  "keywords": [
    "browser-extension",
    "chrome-extension",
    "firefox-extension",
    "edge-extension",
    "web-extension",
    "wxt",
    "manifest-v3",
    "react",
    "react-19",
    "radix-ui",
    "typescript",
    "zustand",
    "boilerplate",
    "template",
    "starter"
  ],
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:all": "wxt build && wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:all": "wxt zip && wxt zip -b firefox",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "wxt": "^0.20.26"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.14.1"
}
